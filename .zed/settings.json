{
	"format_on_save": "on",
	"formatter": "prettier",
	"code_actions_on_format": {
		"source.fixAll.eslint": true
	},
	"lsp": {
		"eslint": {
			"settings": {
				"useFlatConfig": true,
				"workingDirectory": {
					"mode": "auto"
				}
			}
		}
	},
	"languages": {
		"TypeScript": {
			"language_servers": ["eslint", "vtsls"]
		},
		"TSX": {
			"language_servers": ["eslint", "vtsls", "tailwindcss-language-server"]
		},
		"JavaScript": {
			"language_servers": ["eslint", "vtsls"]
		}
	}
}
